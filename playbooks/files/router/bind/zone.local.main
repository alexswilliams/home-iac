$TTL 10m
@ IN SOA router-pi.main.local. hostmaster.local. (
  2026011801  ; serial
  1m          ; secondary server refresh interval
  1m          ; secondary sever retry interval
  365d        ; secondary server expire-on-split-brain duratoin
  10          ; nxdomain cache time
)

  IN NS router-pi.main.local.

router-pi             IN  A     192.168.2.2
desktop-wired         IN  A     192.168.2.10
desktop               IN  CNAME desktop-wired.main.local.
laptop-wired          IN  A     192.168.2.11
laptop-wifi           IN  A     192.168.2.12
pixel-4               IN  A     192.168.2.200
pixel-6               IN  A     192.168.2.201
pixel-8               IN  A     192.168.2.202
