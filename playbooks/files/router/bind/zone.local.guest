$TTL 10m
@ IN SOA router-pi.guest.local. hostmaster.local. (
  2026011801  ; serial
  1m          ; secondary server refresh interval
  1m          ; secondary sever retry interval
  365d        ; secondary server expire-on-split-brain duratoin
  10          ; nxdomain cache time
)

  IN NS router-pi.guest.local.

router-pi             IN  A     192.168.100.2
