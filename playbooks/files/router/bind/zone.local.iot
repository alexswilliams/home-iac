$TTL 10m
@ IN SOA router-pi.iot.local. hostmaster.local. (
  2026011801  ; serial
  1m          ; secondary server refresh interval
  1m          ; secondary sever retry interval
  365d        ; secondary server expire-on-split-brain duratoin
  10          ; nxdomain cache time
)

  IN NS router-pi.iot.local.

router-pi             IN  A     192.168.5.2

garmin-vivoactive     IN  A     192.168.5.10

kl130b-living-room    IN  A     192.168.5.40
