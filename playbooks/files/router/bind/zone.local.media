$TTL 10m
@ IN SOA router-pi.media.local. hostmaster.local. (
  2026011801  ; serial
  1m          ; secondary server refresh interval
  1m          ; secondary sever retry interval
  365d        ; secondary server expire-on-split-brain duratoin
  10          ; nxdomain cache time
)

  IN NS router-pi.media.local.

router-pi             IN  A     192.168.4.2
amazon-tv-wired       IN  A     192.168.4.10
amazon-tv-wifi        IN  A     192.168.4.11
chromecast-wired      IN  A     192.168.4.12
chromecast-wifi       IN  A     192.168.4.13
pixel-4               IN  A     192.168.4.200
pixel-6               IN  A     192.168.4.201
pixel-8               IN  A     192.168.4.202
