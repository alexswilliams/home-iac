$TTL 10m
@ IN SOA router-pi.work.local. hostmaster.local. (
  2026011801  ; serial
  1m          ; secondary server refresh interval
  1m          ; secondary sever retry interval
  365d        ; secondary server expire-on-split-brain duratoin
  10          ; nxdomain cache time
)

  IN NS router-pi.work.local.

router-pi             IN  A     192.168.3.2
m1-wifi               IN  A     192.168.3.10
dock-wired            IN  A     192.168.3.11
thunderbolt-nic       IN  A     192.168.3.12
