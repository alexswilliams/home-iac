[Unit]
Description=nftables-post-up
Wants=network-online.target
After=network-online.target
DefaultDependencies=no

[Service]
Type=oneshot
RemainAfterExit=yes
StandardInput=null
ProtectSystem=full
ProtectHome=true
ExecStart=/usr/sbin/nft -o -f /etc/nftables.conf

[Install]
WantedBy=multi-user.target
